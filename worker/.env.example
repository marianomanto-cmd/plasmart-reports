# ============================================================
# Worker de render — Motor de contenido Plasmart (Fase 8)
# ============================================================
# Copiá este archivo a `.env` en la PC del worker y completá los valores.
# NUNCA commitear el .env real.

# --- Identidad del worker ---
# Cualquier string estable que identifique esta PC en la cola/heartbeat.
WORKER_ID=taller-pc-01

# Cada cuántos ms el worker le pregunta a Supabase si hay un job pending.
POLL_INTERVAL_MS=5000

# Timeout (ms) para considerar "colgado" un job en processing y recuperarlo.
JOB_TIMEOUT_MS=600000

# --- Supabase (se enchufa en 8.3, cuando existan las tablas) ---
# URL del proyecto Supabase al que apunta este branch (idealmente el proyecto
# free APARTE para Preview, no el de producción).
SUPABASE_URL=
# Service Role Key: SOLO vive acá, en la PC. Nunca en el cliente ni en Vercel.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Drive (banco de imágenes + salida de videos) ---
# El MISMO Service Account JSON que usa la ingesta de reportes, en una línea.
# Necesita acceso de LECTURA al banco y de ESCRITURA a /videos/.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ID de la carpeta de Drive del banco de imágenes (/plasmart-content/banco/).
DRIVE_FOLDER_BANCO=
# ID de la carpeta de Drive donde se suben los MP4 (/plasmart-content/videos/).
DRIVE_FOLDER_VIDEOS=

# --- Banco montado localmente (opcional, alternativa a la API de Drive) ---
# Si la carpeta del banco está montada (Drive para Escritorio / rclone),
# poné la ruta acá y el worker lee del disco en vez de la API.
BANCO_LOCAL_PATH=

# --- Depth Anything (parallax 2.5D) ---
# Ruta al python del entorno con Depth Anything instalado en la PC.
# Si queda vacío, el worker cae a parallax 2D sin mapa de profundidad.
DEPTH_PYTHON_BIN=
