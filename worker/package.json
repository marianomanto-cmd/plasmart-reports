    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
