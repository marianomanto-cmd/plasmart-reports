# === SUPABASE ===
# Public (frontend) - se exponen al cliente
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Secret (server-side only) - NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# === ANTHROPIC ===
# Secret (server-side only) - usado por la Edge Function de análisis
ANTHROPIC_API_KEY=sk-ant-api03-...

# === GOOGLE OAUTH ===
# Configurado en Supabase Auth, no se usa directamente en el código
# Pero documentamos los valores aquí para referencia:
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_HOSTED_DOMAIN=transfil.com.ar

# === GOOGLE SERVICE ACCOUNT (para Drive/Sheets) ===
# Se guarda como secret en Supabase Edge Functions, no acá
# Documentado solo para referencia:
# GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_KEY=---BEGIN PRIVATE KEY---...

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === MOTOR DE CONTENIDO (Fase 8, branch) ===
# Sólo necesarias si vas a probar /contenido en el Preview de Vercel o local.
# Detalle en docs/fase8-contenido.md.
#
# Service Account JSON en UNA línea — reusar el mismo de la ingesta. Necesita
# acceso de LECTURA a /plasmart-content/banco/ y /videos/. Server-only.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"..."}
#
# Folder ID de la carpeta de Drive del banco de imágenes.
# DRIVE_FOLDER_BANCO=
#
# Modelo de Claude para el cerebro editorial (default: claude-haiku-4-5).
# ANTHROPIC_CONTENT_MODEL=claude-haiku-4-5
#
# DRIVE_FOLDER_VIDEOS y las credenciales con permiso de ESCRITURA viven en
# worker/.env (la PC del worker), NO acá. Ver worker/.env.example.
